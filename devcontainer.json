{
    "name": "Aula Python com Streamlit",
    "image": "mcr.microsoft.com/devcontainers/python:3",
    "forwardPorts": [
        8501
    ],
    "portsAttributes": {
        "8501": {
            "label": "Streamlit App",
            "onAutoForward": "openBrowser"
        }
    },
    "postCreateCommand": "pip install streamlit",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}